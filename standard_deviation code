#include<iostream>
#include<cmath>

using namespace std;
double stdev(double x[],int n){
    double mean=0,sum=0;
    for(int i=0;i<n;i++)
        mean+=x[i];
    mean=mean/n;
    for(int i=0;i<n;i++)
        sum+=(x[i]-mean)*(x[i]-mean);
    return sqrt(sum/(n-1));
}
int main(){
    double arr[5];
    for(int i=0;i<5;i++){
        cout<<"Enter number "<<i+1<<": ";
        cin>>arr[i];
    }
    cout<<"Standard deviation = "<<stdev(arr,5);
    return 0;
}
