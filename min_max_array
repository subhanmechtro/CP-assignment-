#include<iostream>
using namespace std;

void getExtremes(float& min,float& max,float a[],int n){
    min=a[0];
    max=a[0];
    for(int i=1;i<n;i++){
        if(a[i]<min)
            min=a[i];
        if(a[i]>max)
            max=a[i];
    }
}
int main(){
    float arr[5],min,max;
    for(int i=0;i<5;i++){
        cout<<"Enter value "<<i+1<<": ";
        cin>>arr[i];
    }
    getExtremes(min,max,arr,5);
    cout<<"Minimum value = "<<min<<endl;
    cout<<"Maximum value = "<<max<<endl;
    return 0;
}
