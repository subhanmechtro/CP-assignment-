#include<iostream>
using namespace std;

// Function to input values in matrix
void GetValue(int a[3][3]){
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cout<<"Enter value for ["<<i<<"]["<<j<<"]: ";
            cin>>a[i][j];
        }
    }
}
// Function to multiply matrix by itself
void ComputeAxA(int a[3][3],int result[3][3]){
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            result[i][j]=0;
            for(int k=0;k<3;k++){
                result[i][j]+=a[i][k]*a[k][j];
            }
        }
    }
}
// Function to print matrix
void PrintArray(int a[3][3]){
    for(int i=0;i<3;i++){
        for(int j=0;j<3;j++){
            cout<<a[i][j]<<" ";
        }
        cout<<endl;
    }
}
int main(){
    int a[3][3],result[3][3];
    // Taking matrix input
    cout<<"Enter elements of matrix:"<<endl;
    GetValue(a);
    // Multiplying matrix
    ComputeAxA(a,result);
    // Printing result
    cout<<"\nResultant matrix:"<<endl;
    PrintArray(result);
    return 0;
}
